# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — server only, never exposed

# ── Square ─────────────────────────────────────────────────────────────────
SQUARE_ENV=sandbox                                # 'sandbox' while testing, 'production' when live
SQUARE_ACCESS_TOKEN=your-square-access-token      # SECRET — server only
SQUARE_LOCATION_ID=your-location-id
NEXT_PUBLIC_SQUARE_APP_ID=your-square-application-id   # safe to expose (used by Web Payments SDK)
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-location-id        # safe to expose

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_DOMAIN=knoxhd.com

# ── Notifications (media-ready alerts) ───────────────────────────────────
RESEND_API_KEY=your-resend-api-key                # SECRET — server only
NOTIFY_FROM_EMAIL=delivery@knoxhd.com             # verified sender in Resend
TWILIO_ACCOUNT_SID=your-twilio-sid                # SECRET — server only
TWILIO_AUTH_TOKEN=your-twilio-auth-token          # SECRET — server only
TWILIO_FROM_NUMBER=+14235551234                   # your Twilio SMS number
ADMIN_EMAILS=james@knoxhd.com                     # comma-separated; who may access /admin
